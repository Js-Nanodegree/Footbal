{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"]
    },
    "lib": ["es2015", "dom"]
  },
  "include": ["src", "ReactotronConfig.ts"]
}